            "additionalProperties": false
          },
          "height": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "enum": [
                  "autofit",
                  "points",
                  "standard"
                ]
              },
              "value": {
                "type": "number"
              }
            },
            "required": [
              "type"
            ],
            "additionalProperties": false
          },
          "summary": {
            "type": "string",
            "description": "Short label shown next to the tool icon. 4-8 words describing in active tense what is happening",
            "maxLength": 40
          }
        },
        "required": [
          "sheetId"
        ],
        "additionalProperties": false
      }
    },
    {
