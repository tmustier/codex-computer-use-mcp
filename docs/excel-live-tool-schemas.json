                "type": "string",
                "description": "Hex or named background fill color."
              },
              "horizontalAlignment": {
                "type": "string",
                "enum": [
                  "left",
                  "center",
                  "right"
                ],
                "description": "Horizontal text alignment."
              },
              "numberFormat": {
                "type": "string",
                "description": "Excel number format string."
              },
              "borders": {
                "type": "array",
                "description": "Condensed border model. Each entry applies the same border style to one or more sides.",
                "items": {
                  "type": "object",
                  "properties": {
                    "sides": {
                      "type": "array",
                      "items": {
                        "type": "string",
                        "enum": [
                          "top",
                          "bottom",
                          "left",
                          "right"
                        ]
                      },
                      "minItems": 1,
                      "description": "Which sides of the cell to apply this border definition to."
                    },
                    "style": {
                      "type": "string",
                      "enum": [
                        "solid",
                        "dashed",
                        "dotted",
                        "double"
                      ],
                      "description": "Line style of the border."
                    },
                    "weight": {
                      "type": "string",
                      "enum": [
                        "thin",
                        "medium",
                        "thick"
                      ],
                      "description": "Thickness of the border."
                    },
                    "color": {
                      "type": "string",
                      "description": "Hex or named color of the border."
                    }
                  },
                  "required": [
                    "sides",
                    "style",
                    "weight"
                  ],
                  "additionalProperties": false
                }
              }
            },
            "additionalProperties": false
          },
          "summary": {
            "type": "string",
            "description": "Short label shown next to the tool icon. 4-8 words describing in active tense what is happening",
            "maxLength": 40
          }
        },
        "required": [
          "sheetId",
          "range",
          "cellStyles"
        ],
        "additionalProperties": false
      }
    },
    {
      "surface": "excel",
      "tool_name": "chart",
      "version": "1",
      "description": "Create, update, or delete a chart.",
      "input_schema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "summary": {
            "type": "string",
            "maxLength": 40,
            "description": "4–8 words, active tense."
          },
          "operation": {
            "type": "string",
            "enum": [
              "create",
              "update",
              "delete"
            ]
          },
          "sheetId": {
            "type": "string"
          },
          "id": {
            "type": "string",
            "description": "Chart ID (update/delete)."
          },
          "properties": {
            "type": "object",
            "additionalProperties": false,
            "description": "Chart properties. For create: source + chartType required (enforced by runtime).",
            "properties": {
              "name": {
                "type": "string"
              },
              "title": {
                "type": "string"
              },
              "chartType": {
                "type": "string",
                "enum": [
                  "ColumnClustered",
