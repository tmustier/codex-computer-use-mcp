            "description": "Toggle right-to-left sheet display if supported."
          },
          "summary": {
            "type": "string",
            "description": "Short label shown next to the tool icon. 4-8 words describing in active tense what is happening",
            "maxLength": 40
          }
        },
        "required": [
          "sheetId"
        ],
        "additionalProperties": false
      }
    },
    {
